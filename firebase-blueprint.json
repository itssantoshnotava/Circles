{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "photoURL": { "type": "string" },
        "dob": { "type": "string" },
        "isGuest": { "type": "boolean" },
        "profileSetupComplete": { "type": "boolean" },
        "selectedTimerMode": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid"]
    },
    "Room": {
      "title": "Room",
      "description": "Study room information",
      "type": "object",
      "properties": {
        "roomId": { "type": "string" },
        "hostId": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" },
        "timerState": {
          "type": "object",
          "properties": {
            "timeLeft": { "type": "number" },
            "isRunning": { "type": "boolean" },
            "mode": { "type": "string", "enum": ["pomodoro", "shortBreak", "longBreak"] },
            "lastUpdated": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["roomId", "hostId", "participants", "createdAt", "active"]
    },
    "RoomMessage": {
      "title": "RoomMessage",
      "description": "Chat message in a room",
      "type": "object",
      "properties": {
        "roomId": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "profilePic": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["roomId", "userId", "username", "message", "createdAt"]
    },
    "Progress": {
      "title": "Progress",
      "description": "User progress tracker",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "subject": { "type": "string" },
        "completedChapters": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "subject", "completedChapters"]
    },
    "FriendRequest": {
      "title": "FriendRequest",
      "description": "Friend request between users",
      "type": "object",
      "properties": {
        "fromUserId": { "type": "string" },
        "toUserId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUserId", "toUserId", "status", "createdAt"]
    },
    "Friend": {
      "title": "Friend",
      "description": "Friendship between users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "friendId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "friendId", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "fromUserId": { "type": "string" },
        "toUserId": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "fromUserId", "toUserId", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Study rooms"
    },
    "/roomMessages/{messageId}": {
      "schema": "RoomMessage",
      "description": "Room chat messages"
    },
    "/progress/{progressId}": {
      "schema": "Progress",
      "description": "User progress data"
    },
    "/friendRequests/{requestId}": {
      "schema": "FriendRequest",
      "description": "Friend requests"
    },
    "/friends/{friendshipId}": {
      "schema": "Friend",
      "description": "Friendships"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
